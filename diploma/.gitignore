# ═══════════════════════════════════════════════════════════════════════════
# TariffRadar .gitignore — Что НЕ загружаем на GitHub
# ═══════════════════════════════════════════════════════════════════════════

# Go & Build
bin/
*.o
*.a
*.so
dist/
build/
*.exe
*.dll
go.sum

# Node.js & Frontend
node_modules/
npm-debug.log*
yarn-error.log*
.pnp
.pnp.js

# Environment & Secrets
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.code-workspace

# Docker
.docker/
docker-compose.override.yml

# Database
*.db
*.sqlite
migrations/*.sql~

# Logs
*.log
logs/

# Temporary & Cache
tmp/
temp/
*.tmp
.cache/
__pycache__/

# OS
Thumbs.db
.DS_Store

# ═══════════════════════════════════════════════════════════════════════════
# ЛИЧНЫЕ ФАЙЛЫ — НЕ ВЫКЛАДЫВАЕМ НА GITHUB
# ═══════════════════════════════════════════════════════════════════════════

# Дипломная работа (personal documents, .docx, .xlsx)
diploma/
diploma/**
*.docx
*.docx~
~*.docx
*.xlsx
*.xlsx~

# Папка практики (личные файлы)
практика/
практика/**

# Примеры дипломов (справка, не часть кода)
пример-диплома/
пример-диплома/**
примеры/
примеры/**

# Инструкции для Claude (внутренние, не для GitHub)
CLAUDE.md
CLAUDE.*.md

# Test coverage
*.out
coverage.html
.coverage

# Vendored libraries (if used)
vendor/
Godeps/
